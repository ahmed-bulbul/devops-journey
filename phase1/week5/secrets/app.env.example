# app.env.example — copy to app.env and fill in real values
# NEVER commit app.env to git — add it to .gitignore
#
# cp secrets/app.env.example secrets/app.env
# nano secrets/app.env

DB_PASSWORD=changeme_use_strong_password
MYSQL_ROOT_PASSWORD=changeme_root_password
REDIS_PASSWORD=changeme_redis_password
JWT_SECRET=changeme_jwt_secret_min_32_chars
