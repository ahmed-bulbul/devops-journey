# /etc/nginx/sites-available/springboot-proxy
#
# Reverse proxy: nginx (port 80) → Spring Boot app (port 8080)
#
# Setup steps:
#   sudo cp springboot-proxy /etc/nginx/sites-available/
#   sudo ln -s /etc/nginx/sites-available/springboot-proxy /etc/nginx/sites-enabled/
#   sudo nginx -t          # test config
#   sudo systemctl reload nginx

upstream springboot_app {
    server 127.0.0.1:8080;      # your Spring Boot app
    # Add more instances for load balancing:
    # server 127.0.0.1:8081;
}

server {
    listen 80;
    server_name localhost;       # replace with your domain or IP

    # ─── Proxy to Spring Boot ─────────────────────────────────────────────────
    location / {
        proxy_pass         http://springboot_app;
        proxy_http_version 1.1;

        # Pass real client info to the app
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Timeouts
        proxy_connect_timeout 10s;
        proxy_read_timeout    60s;
    }

    # ─── Health check endpoint (bypass proxy, serve locally) ──────────────────
    location /nginx-health {
        return 200 "nginx ok\n";
        add_header Content-Type text/plain;
    }

    # ─── Static assets (optional — serve directly, skip Spring Boot) ──────────
    location /static/ {
        root /var/www/myapp;
        expires 30d;
    }

    # ─── Logging ──────────────────────────────────────────────────────────────
    access_log /var/log/nginx/springboot_access.log;
    error_log  /var/log/nginx/springboot_error.log;
}
